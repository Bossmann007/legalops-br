# Maffini Dashboard — Environment Variables
# Copy to .env (gitignored) and fill real values.
# In production: provision via secret manager (Vault, AWS SM, sealed-secret).
# Always: `chmod 600 .env`

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Login auth (single user, basic auth)
# ─────────────────────────────────────────────────────────────────────────────
# Modo padrão single-user (Dra. Maylin na própria máquina): SEM login.
#   - Deixe MAFFINI_AUTH_USER vazio/unset → a parede de basic-auth é pulada.
#   - Exigência: o servidor SÓ sobe assim se MAFFINI_HOST for loopback
#     (127.0.0.1 / ::1 / localhost). Em host não-loopback, o boot FALHA
#     com mensagem clara — nunca expõe dashboard sem login numa interface LAN/WAN.
#
# Para habilitar login (obrigatório se for expor em LAN/VPS): defina USER + PASS.
# MAFFINI_AUTH_USER=maylin
# Senha — em prod use scrypt HASH (nunca plaintext):
#   node -e "console.log(require('./server/lib/auth').hashPassword('senha'))"
# Plaintext aceito apenas em dev:
# MAFFINI_AUTH_PASS=replace-with-strong-password
# Quando definido, usa scrypt-hash em vez de plaintext compare:
# MAFFINI_AUTH_PASS_HASH=scrypt$salt$hex
#
# NOTA: o approval gate por-comando (modal confirm + 403 quando approved!==true)
# é INDEPENDENTE do login e fica SEMPRE ativo — nada roda sem autorização.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — LegalOps integration
# ─────────────────────────────────────────────────────────────────────────────
# Salt secreto pra pseudonimização PII (LGPD Art. 13). 16+ bytes.
# Gere: openssl rand -hex 24
LEGALOPS_PII_SALT=replace-with-openssl-rand-hex-24

# Caminho do binário legalops (default tenta PATH). Use venv path em dev:
LEGALOPS_BIN=/home/bossmann/Projects/legalops-br/.venv/bin/legalops

# Audit DB path (compartilhado com legalops). Default: data/audit.db (relativo ao repo)
LEGALOPS_AUDIT_DB=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Defense in depth
# ─────────────────────────────────────────────────────────────────────────────
# HMAC key pra tamper-evidence audit chain.
# LEGALOPS_AUDIT_HMAC_KEY=

# SMTP secret pra notify email (precedência sobre TOML config).
# LEGALOPS_SMTP_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Claude for Legal (egress LLM, opt-in)
# ─────────────────────────────────────────────────────────────────────────────
# Habilita os comandos cfl_* (grupo "Claude for Legal"). ATENÇÃO: quando setado,
# o texto é REDIGIDO via `legalops redact` e só o texto REDIGIDO é enviado à
# Anthropic (api.anthropic.com). Sem esta key, os comandos cfl_* retornam 501.
# ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
MAFFINI_PORT=4318
MAFFINI_HOST=127.0.0.1
# CORS allowlist (vírgula). Default: same-origin only.
# MAFFINI_CORS=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Microsoft 365 ingest (Outlook intimações)
# ─────────────────────────────────────────────────────────────────────────────
# LEGALOPS_M365_TENANT_ID=
# LEGALOPS_M365_CLIENT_ID=
# LEGALOPS_M365_CLIENT_SECRET=
# LEGALOPS_M365_USER_PRINCIPAL_NAME=maylin@maffiniadvocacia.com.br
