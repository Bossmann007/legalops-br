{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ cat \"${CLAUDE_PLUGIN_ROOT}/memory.local/primer.local.md\" 2>/dev/null || cat \"${CLAUDE_PLUGIN_ROOT}/memory/Primer.md\" 2>/dev/null; echo; cat \"${CLAUDE_PLUGIN_ROOT}/RULES.md\" 2>/dev/null; }",
            "statusMessage": "Carregando estado e regras do escritório..."
          },
          {
            "type": "command",
            "command": "echo \"👋 Bom dia. 3 coisas: /varrer (checar intimações novas) · /painel (seus prazos) · /briefing (resumo do dia). Última varredura aparece no /painel.\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/anti-injection/hooks/flag-llm-paste.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/anti-injection/hooks/scan-injection.mjs\""
          }
        ]
      }
    ]
  }
}
