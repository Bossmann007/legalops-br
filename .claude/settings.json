{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ cat \"$CLAUDE_PROJECT_DIR/.claude/memory.local/primer.local.md\" 2>/dev/null || cat \"$CLAUDE_PROJECT_DIR/.claude/memory/Primer.md\" 2>/dev/null; echo; cat \"$CLAUDE_PROJECT_DIR/.claude/RULES.md\" 2>/dev/null; }",
            "statusMessage": "Carregando estado e regras do escritório..."
          },
          {
            "type": "command",
            "command": "echo \"👋 Bom dia. 3 coisas: /varrer (checar intimações novas) · /painel (seus prazos) · /briefing (resumo do dia). Última varredura aparece no /painel.\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/anti-injection/hooks/flag-llm-paste.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/anti-injection/hooks/scan-injection.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run pytest --tb=no -q 2>&1 | tail -3",
            "statusMessage": "Running legalops tests..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"⚖️ LEGALOPS: Verifique — tipo hints obrigatórios, sem PII real em tests, cobertura ≥95% em código crítico\"}'"
          }
        ]
      }
    ]
  }
}
