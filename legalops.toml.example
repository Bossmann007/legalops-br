# LegalOps BR config example.
# Copy to ~/.config/legalops/config.toml and customize.

[defaults]
parte = "particular"   # particular | fazenda | mp | defensoria
via_dje = false        # if true, intimacao via DJE: dies a quo + 1 dia util
tribunal = "TJPR"      # TJPR | TJSP | TJSC | TJRJ

[audit]
db = "~/.local/share/legalops/audit.db"

[whatsapp]
chat_id = "5541999999999@s.whatsapp.net"
bridge_url = "http://localhost:3000"
timeout = 10.0

[email]
smtp_host = "smtp.gmail.com"
smtp_port = 587
username = "ops@firma.com"
password = "app-password-here"
from_addr = "ops@firma.com"
to_addr = "advogado@firma.com"
use_tls = true

[slack]
webhook_url = "https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"
channel = "#prazos"   # opcional; webhook ja tem default

[notification]
channels = ["whatsapp", "email", "slack"]
min_prazo_days = 3      # so notifica prazos <= N dias uteis
quiet_start = "22:00"   # janela silencio: nao envia (24h ok)
quiet_end = "06:00"
